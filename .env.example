# LLM Provider Configuration
# Choose either 'gemini' or 'openai'
LLM_PROVIDER=gemini

# API Keys (fill this in your local .env, DO NOT commit to git!)
GEMINI_API_KEY=your_gemini_api_key_here
OPENAI_API_KEY=your_openai_api_key_here

# Model Selection
# For gemini: text-embedding-004 and gemini-1.5-flash are default
# For openai: text-embedding-3-small and gpt-4o-mini are default
EMBED_MODEL=
CHAT_MODEL=

# Database configuration
DATABASE_PATH=data/knowledge.db
