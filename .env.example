# LLM Provider Configuration
# Controls the embedding provider (and chat provider when CHAT_PROVIDER is not set)
# Options: gemini, openai, ollama, local, none
LLM_PROVIDER=gemini

# Chat Provider (optional — defaults to LLM_PROVIDER)
# Set this to use a different provider for guidance/check-in completions.
# Useful when LLM_PROVIDER=local or none and you want a real chat model.
# Options: gemini, openai, ollama, local, none
# CHAT_PROVIDER=ollama

# API Keys (fill in your local .env, DO NOT commit to git!)
GEMINI_API_KEY=your_gemini_api_key_here
OPENAI_API_KEY=your_openai_api_key_here

# Model Selection
# EMBED_MODEL controls the embedding model (for semantic search).
# CHAT_MODEL controls the chat/completion model.
# When CHAT_PROVIDER is set, CHAT_MODEL applies to that provider.
# For gemini: text-embedding-004 and gemini-1.5-flash are defaults
# For openai: text-embedding-3-small and gpt-4o-mini are defaults
# For ollama: nomic-embed-text and llama3 are defaults
# For local: BAAI/bge-small-en-v1.5 (no chat model)
EMBED_MODEL=
CHAT_MODEL=

# Database configuration
DATABASE_PATH=data/knowledge.db
